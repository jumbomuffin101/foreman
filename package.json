{
  "name": "foreman",
  "version": "1.0.0",
  "description": "Distributed job queue with real-time monitoring dashboard",
  "main": "dist/api/server.js",
  "scripts": {
    "api": "ts-node src/api/server.ts",
    "worker": "ts-node src/workers/worker.ts",
    "dev:api": "nodemon --exec ts-node src/api/server.ts",
    "dev:worker": "nodemon --exec ts-node src/workers/worker.ts",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "seed": "ts-node src/scripts/seed.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jumbomuffin101/foreman.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/jumbomuffin101/foreman/issues"
  },
  "homepage": "https://github.com/jumbomuffin101/foreman#readme",
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "bullmq": "^5.70.4",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ioredis": "^5.10.0",
    "prisma": "^6.16.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.4.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
