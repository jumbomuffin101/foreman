generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id          String   @id @default(cuid())
  type        String
  producerId  String?
  payload     Json
  status      String   @default("waiting")
  attempts    Int      @default(0)
  result      Json?
  error       String?
  createdAt   DateTime @default(now())
  startedAt   DateTime?
  processedAt DateTime?
  failedAt    DateTime?
}
